<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WorkShop Hub – Find & Register for Workshops</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="css/style.css">
</head>
<body>

<!-- ═══ NAV ═══ -->
<div id="app">
<nav id="mainNav">
  <a class="nav-logo" onclick="showScreen('landing')">
    <div class="nav-logo-icon"><svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg></div>
    <div><div class="nav-logo-text">WorkShop Hub</div><div class="nav-logo-sub">Campus Learning Platform</div></div>
  </a>
  <div class="nav-links">
    <a onclick="showScreen('landing')" id="nl-home" class="active">Home</a>
    <a onclick="showScreen('interests')" id="nl-interests">Interests</a>
    <a onclick="showScreen('workshops')" id="nl-workshops">Workshops</a>
    <a onclick="showScreen('analytics')" id="nl-analytics">📊 Analytics</a>
    <a onclick="showScreen('contact')" id="nl-contact">Contact</a>
  </div>
  <div class="nav-right">
    <div class="nav-search">
      <svg viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input type="text" placeholder="Search workshops..." id="globalSearch" onkeyup="handleGlobalSearch(this.value)">
    </div>
    <!-- NOTIFICATION BELL -->
    <div class="notif-bell-wrap" id="notifBellWrap">
      <div class="notif-bell-btn" onclick="toggleNotifPanel()">
        <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        <div class="notif-dot" id="notifDot">3</div>
      </div>
      <div class="notif-dropdown" id="notifDropdown">
        <div class="notif-dhead">
          <h4>🔔 Notifications</h4>
          <span class="notif-mark-all" onclick="markAllRead()">Mark all read</span>
        </div>
        <div class="notif-list" id="notifList"></div>
      </div>
    </div>

    <!-- Dark Mode Toggle -->
    <div style="display:flex;align-items:center;gap:6px;">
      <span style="font-size:.72rem;color:#94A3B8;">🌙</span>
      <button class="dark-toggle" id="darkToggle" onclick="toggleDarkMode()" title="Toggle dark mode"></button>
    </div>
    <div id="navAuthArea">
      <div style="display:flex;gap:8px;">
        <button class="btn btn-outline" style="padding:7px 16px;font-size:.82rem;" onclick="openAuth('login')">Login</button>
        <button class="btn btn-teal" style="padding:7px 16px;font-size:.82rem;" onclick="openAuth('signup')">Sign Up</button>
      </div>
    </div>
    <div id="navUserArea" style="display:none;">
      <div class="user-pill" onclick="toggleUserMenu()">
        <div class="user-avatar" id="navAvatar">P</div>
        <span class="user-name" id="navUserName">User</span>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div id="userMenu" style="display:none;position:absolute;right:20px;top:68px;background:white;border:1.5px solid var(--border);border-radius:14px;padding:8px;min-width:180px;box-shadow:0 10px 32px rgba(0,0,0,.12);z-index:99;">
        <div style="padding:10px 12px;border-bottom:1px solid var(--border);margin-bottom:4px;">
          <div style="font-weight:700;font-size:.88rem;" id="menuUserName">User</div>
          <div style="font-size:.75rem;color:var(--muted);" id="menuUserEmail"><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="d1bcbeb9b0bfb0a1a3b8a8b091babdb9ffb4b5a4ffb8bf">[email&#160;protected]</a></div>
        </div>
        <div onclick="showScreen('dashboard')" style="padding:9px 12px;border-radius:8px;cursor:pointer;font-size:.84rem;font-weight:500;" onmouseover="this.style.background='#F0FDFA'" onmouseout="this.style.background=''">📚 My Dashboard</div>
        <div onclick="doLogout()" style="padding:9px 12px;border-radius:8px;cursor:pointer;font-size:.84rem;font-weight:500;color:var(--danger);" onmouseover="this.style.background='#FEF2F2'" onmouseout="this.style.background=''">🚪 Logout</div>
      </div>
    </div>
  </div>
</nav>

<!-- ═══════════════════════════════════════
     SCREEN 1: LANDING
═══════════════════════════════════════ -->
<div class="screen active" id="screen-landing">
  <!-- HERO -->
  <section class="hero" style="min-height:calc(100vh - 64px);display:flex;align-items:center;overflow:hidden;">
    <div class="hero-blob hb1"></div>
    <div class="hero-blob hb2"></div>
    <div class="hero-inner" style="width:100%;">
      <div class="hero-left">
        <div class="hero-badge"><span class="pulse"></span> 8 Workshops Open for Registration</div>
        <h1>Discover &amp; Join<br>Campus <span class="highlight">Workshops</span><br>&amp; Seminars</h1>
        <p class="hero-desc">Browse expert-led workshops, register in seconds, and level up your skills — all from one campus platform.</p>
        <div class="hero-cta">
          <button class="btn btn-teal" style="padding:13px 28px;font-size:.95rem;" onclick="showScreen('workshops')">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            Browse Workshops
          </button>
          <button class="btn btn-outline" style="padding:13px 24px;font-size:.95rem;" onclick="openAuth('signup')">Get Started Free</button>
        </div>
        <div class="hero-stats">
          <div class="hstat"><div class="hstat-n">8+</div><div class="hstat-l">Workshops</div></div>
          <div class="hstat"><div class="hstat-n">247</div><div class="hstat-l">Registered</div></div>
          <div class="hstat"><div class="hstat-n">12</div><div class="hstat-l">Instructors</div></div>
        </div>
      </div>
      <div class="hero-right reveal">
        <div class="float-card fc1" style="font-size:.78rem;display:flex;align-items:center;gap:8px;">
          <span style="width:28px;height:28px;background:#ECFDF5;border-radius:8px;display:grid;place-items:center;">✅</span>
          <div><div style="font-weight:700;">Registration Open</div><div style="color:var(--muted);font-size:.7rem;">8 workshops available</div></div>
        </div>
        <div class="hero-card-main">
          <h3>🗓 Upcoming Workshops</h3>
          <div id="heroUpcoming"></div>
        </div>
        <div class="float-card fc2" style="font-size:.78rem;display:flex;align-items:center;gap:8px;">
          <span style="font-size:1.2rem;">🔥</span>
          <div><div style="font-weight:700;">40+ Seats Available</div><div style="color:var(--muted);font-size:.7rem;">Register before it fills up!</div></div>
        </div>
      </div>
    </div>
  </section>
</div>


<!-- ═══ SCREEN: INTERESTS ═══ -->
<div class="screen" id="screen-interests">
  <div style="padding:48px 5% 60px;max-width:1100px;margin:0 auto;">
    <div class="sec-tag">Explore by Topic</div>
    <h2 class="sec-title">Find Your <em>Interest</em></h2>
    <div class="cat-grid" style="margin-top:28px;">
      <div class="cat-card reveal" onclick="filterAndGo('Tech')"><div class="cat-icon">💻</div><div class="cat-name">Technology</div><div class="cat-count">3 workshops</div></div>
      <div class="cat-card reveal" style="transition-delay:.1s" onclick="filterAndGo('Design')"><div class="cat-icon">🎨</div><div class="cat-name">Design</div><div class="cat-count">1 workshop</div></div>
      <div class="cat-card reveal" style="transition-delay:.2s" onclick="filterAndGo('Data')"><div class="cat-icon">📊</div><div class="cat-name">Data &amp; AI</div><div class="cat-count">2 workshops</div></div>
      <div class="cat-card reveal" style="transition-delay:.3s" onclick="filterAndGo('Soft')"><div class="cat-icon">🎤</div><div class="cat-name">Soft Skills</div><div class="cat-count">2 workshops</div></div>
    </div>
    <div style="margin-top:48px;">
      <div class="sec-tag">Featured</div>
      <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;">
        <h2 class="sec-title" style="margin-bottom:0;">Popular <em>Workshops</em></h2>
        <button class="btn btn-outline" onclick="showScreen('workshops')">View All →</button>
      </div>
      <div class="ws-grid" id="featuredGrid"></div>
    </div>
  </div>
</div>

<!-- ═══ SCREEN: CONTACT ═══ -->
<div class="screen" id="screen-contact">
  <div style="min-height:calc(100vh - 64px);display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#122649,#1B3A6B);">
    <div style="max-width:700px;width:90%;text-align:center;color:white;">
      <div style="font-size:3rem;margin-bottom:16px;">📬</div>
      <h2 style="font-family:'Playfair Display',serif;font-size:2rem;font-weight:800;margin-bottom:10px;">Need Help? Contact Us</h2>
      <p style="opacity:.75;margin-bottom:36px;font-size:.95rem;line-height:1.7;">We're here to help with any questions about workshops or registration.</p>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:36px;">
        <div style="background:rgba(255,255,255,.12);border-radius:14px;padding:22px;text-align:center;">
          <div style="font-size:1.8rem;margin-bottom:8px;">📧</div>
          <div style="font-size:.72rem;opacity:.65;margin-bottom:4px;text-transform:uppercase;letter-spacing:.08em;">Email</div>
          <div style="font-size:.88rem;font-weight:700;"><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="6a0705020b040b1a1803130b2a010602440f0e1f440304">[email&#160;protected]</a></div>
        </div>
        <div style="background:rgba(255,255,255,.12);border-radius:14px;padding:22px;text-align:center;">
          <div style="font-size:1.8rem;margin-bottom:8px;">📞</div>
          <div style="font-size:.72rem;opacity:.65;margin-bottom:4px;text-transform:uppercase;letter-spacing:.08em;">Phone</div>
          <div style="font-size:.88rem;font-weight:700;">+91 98858 92444</div>
        </div>
        <div style="background:rgba(255,255,255,.12);border-radius:14px;padding:22px;text-align:center;">
          <div style="font-size:1.8rem;margin-bottom:8px;">🕐</div>
          <div style="font-size:.72rem;opacity:.65;margin-bottom:4px;text-transform:uppercase;letter-spacing:.08em;">Office Hours</div>
          <div style="font-size:.88rem;font-weight:700;">Mon–Fri 9 AM – 5 PM</div>
        </div>
      </div>
      <div style="background:rgba(255,255,255,.08);border-radius:16px;padding:24px;">
        <div style="font-size:.8rem;opacity:.6;margin-bottom:6px;">📍 Campus Address</div>
        <div style="font-weight:600;font-size:.92rem;">KL University, Hyderabad · Bowrampet – 500 043</div>
        <div style="opacity:.6;font-size:.8rem;margin-top:4px;">www.kluniversity.in/hyderabad</div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════
     SCREEN 2: WORKSHOPS LIST
═══════════════════════════════════════ -->
<div class="screen" id="screen-workshops">
  <div id="workshopsScreen">
    <div class="ws-header">
      <h1>All Workshops</h1>
      <p>Browse and find the perfect workshop for you</p>
      <div class="ws-search-bar">
        <div class="ws-search-input">
          <svg viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input type="text" placeholder="Search workshops, instructors..." id="wsSearch" onkeyup="filterWorkshops()">
        </div>
        <div class="ws-filter-tabs">
          <div class="ws-tab active" onclick="setWsFilter('all',this)">All</div>
          <div class="ws-tab" onclick="setWsFilter('online',this)">🌐 Online</div>
          <div class="ws-tab" onclick="setWsFilter('offline',this)">📍 Offline</div>
          <div class="ws-tab" onclick="setWsFilter('upcoming',this)">🗓 Upcoming</div>
        </div>
        <button style="padding:8px 14px;background:#F8FAFC;border:1.5px solid #E2E8F0;border-radius:8px;font-size:.78rem;font-weight:700;color:#374151;cursor:pointer;font-family:'DM Sans',sans-serif;transition:.15s;white-space:nowrap;" onclick="toggleAdvFilter()" id="advFilterToggle">⚙️ Filters</button>
      </div>
    </div>
    <div class="ws-body">
      <!-- Advanced filter bar -->
      <div class="adv-filter-bar" id="advFilterBar" style="display:none">
        <div class="adv-filter-row">
          <select class="adv-select" id="afCategory" onchange="applyAdvFilters()">
            <option value="">All Categories</option>
            <option value="Tech">💻 Technology</option>
            <option value="Data">📊 Data & AI</option>
            <option value="Design">🎨 Design</option>
            <option value="Soft">🎤 Soft Skills</option>
          </select>
          <select class="adv-select" id="afInstructor" onchange="applyAdvFilters()">
            <option value="">All Instructors</option>
          </select>
          <select class="adv-select" id="afSeats" onchange="applyAdvFilters()">
            <option value="">Any Availability</option>
            <option value="open">Has Seats Available</option>
            <option value="low">Low Seats (&lt;10)</option>
            <option value="full">Fully Booked</option>
          </select>
          <select class="adv-select" id="afType" onchange="applyAdvFilters()">
            <option value="">Online &amp; Offline</option>
            <option value="online">🌐 Online Only</option>
            <option value="offline">📍 Offline Only</option>
          </select>
          <button onclick="clearAdvFilters()" style="padding:8px 14px;background:#FEF2F2;border:1.5px solid #FECACA;border-radius:8px;font-size:.78rem;font-weight:700;color:#DC2626;cursor:pointer;font-family:'DM Sans',sans-serif;">✕ Clear</button>
        </div>
        <div class="adv-filter-chips" id="afChips"></div>
      </div>
      <div style="font-size:.78rem;color:#94A3B8;margin-bottom:10px;" id="wsResultCount"></div>
      <div class="ws-grid" id="workshopsGrid"></div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════
     SCREEN 3: WORKSHOP DETAIL
═══════════════════════════════════════ -->
<div class="screen" id="screen-detail">
  <div id="detailScreen">
    <div class="detail-hero">
      <div style="max-width:1200px;margin:0 auto;">
        <div class="breadcrumb">
          <a onclick="showScreen('landing')">Home</a> /
          <a onclick="showScreen('workshops')">Workshops</a> /
          <span id="dBreadcrumb" style="color:rgba(255,255,255,.6);">Workshop</span>
        </div>
        <div class="detail-hero-inner">
          <div>
            <div class="detail-badges">
              <span class="d-badge db-white" id="dTypeBadge">Offline</span>
              <span class="d-badge db-green" id="dStatusBadge">Registration Open</span>
            </div>
            <h1 class="detail-title" id="dTitle">Workshop Title</h1>
          </div>
          <div class="detail-thumb-wrap">
            <div class="detail-thumb-svg" id="dThumb"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="detail-body">
      <div class="detail-main-card">
        <div class="detail-info-grid">
          <div class="dinfo"><div class="dinfo-icon"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div><div><div class="dinfo-label">Date</div><div class="dinfo-value" id="dDate">—</div></div></div>
          <div class="dinfo"><div class="dinfo-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div><div><div class="dinfo-label">Time</div><div class="dinfo-value" id="dTime">—</div></div></div>
          <div class="dinfo"><div class="dinfo-icon"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div><div><div class="dinfo-label">Venue</div><div class="dinfo-value" id="dVenue">—</div></div></div>
          <div class="dinfo"><div class="dinfo-icon"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div><div><div class="dinfo-label">Instructor</div><div class="dinfo-value" id="dInstructor">—</div></div></div>
        </div>
        <div class="detail-desc">
          <h3>About this Workshop</h3>
          <p id="dDesc">—</p>
        </div>
        <div class="detail-agenda">
          <h3>📋 Session Agenda</h3>
          <div id="dAgenda"></div>
        </div>
      </div>
      <div class="detail-side-card">
        <h3>Register for this Workshop</h3>
        <div class="price-row"><span class="price-free">FREE</span><span class="price-sub">No cost to attend</span></div>
        <div class="detail-seat-progress">
          <div class="dsp-label"><span id="dSeatsLabel">Seats</span><span id="dSeatsCount">—</span></div>
          <div class="dsp-bar"><div class="dsp-fill" id="dSeatsFill" style="width:60%"></div></div>
        </div>
        <!-- Countdown Timer -->
        <div class="detail-countdown" id="detailCountdown">
          <div class="detail-countdown-label">⏱️ Workshop starts in</div>
          <div class="ws-countdown" id="detailCountdownUnits">
            <div class="countdown-unit"><span class="cu-val" id="cdDays">--</span><span class="cu-lbl">Days</span></div>
            <div class="countdown-separator">:</div>
            <div class="countdown-unit"><span class="cu-val" id="cdHours">--</span><span class="cu-lbl">Hrs</span></div>
            <div class="countdown-separator">:</div>
            <div class="countdown-unit"><span class="cu-val" id="cdMins">--</span><span class="cu-lbl">Min</span></div>
            <div class="countdown-separator">:</div>
            <div class="countdown-unit"><span class="cu-val" id="cdSecs">--</span><span class="cu-lbl">Sec</span></div>
          </div>
        </div>
        <button class="register-btn" id="registerBtn" onclick="handleRegister()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          Register
        </button>
        <!-- Certificate Preview Button -->
        <button class="cert-btn" id="certBtn" onclick="showCertificate()" style="display:none">
          🎫 View My Certificate
        </button>
        <!-- Live seat countdown -->
        <div class="seat-countdown" id="seatCountdown" style="display:none;">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span id="seatCountdownText">Only X seats left!</span>
        </div>
        <!-- Add to Calendar -->
        <button class="cal-btn" onclick="addToGoogleCalendar()">
          <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Add to Google Calendar
        </button>
        <button class="cal-btn" onclick="addToiCal()">
          <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Download .ics File
        </button>
        <!-- Share Workshop -->
        <div style="font-size:.7rem;font-weight:700;color:#94A3B8;text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px;">Share This Workshop</div>
        <div class="share-row">
          <button class="share-btn sb-wa" onclick="shareWorkshop('whatsapp')">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
            WhatsApp
          </button>
          <button class="share-btn sb-tw" onclick="shareWorkshop('twitter')">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.259 5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Twitter/X
          </button>
          <button class="share-btn sb-cp" onclick="shareWorkshop('copy')">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            Copy Link
          </button>
