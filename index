.ap-nav-logo-sub { font-size:.58rem; color:#94A3B8; display:block; margin-top:-2px; letter-spacing:.04em; }
.ap-nav-links { display:flex; gap:2px; flex:1; }
.ap-nav-link {
  padding:7px 16px; border-radius:8px; font-size:.84rem;
  font-weight:500; color:#64748B; cursor:pointer; transition:.15s;
  border:none; background:none; font-family:'DM Sans',sans-serif;
}
.ap-nav-link:hover { color:#1B3A6B; background:#F1F5F9; }
.ap-nav-link.active { color:#1B3A6B; background:#EEF2FF; font-weight:700; }
.ap-nav-right { display:flex; align-items:center; gap:10px; }
.ap-nav-search {
  display:flex; align-items:center; gap:7px;
  background:#F8FAFC; border:1.5px solid #E2E8F0;
  border-radius:9px; padding:7px 12px;
}
.ap-nav-search input {
  border:none; background:transparent; font-size:.82rem;
  outline:none; width:150px; color:#0D1B2A; font-family:'DM Sans',sans-serif;
}
.ap-nav-search svg { width:14px; height:14px; stroke:#94A3B8; fill:none; flex-shrink:0; }
.ap-notif-bell {
  width:36px; height:36px; background:#F8FAFC; border:1.5px solid #E2E8F0;
  border-radius:9px; display:grid; place-items:center; cursor:pointer; position:relative; transition:.15s;
}
.ap-notif-bell:hover { border-color:#1B3A6B; background:#EEF2FF; }
.ap-notif-bell svg { width:16px; height:16px; stroke:#64748B; fill:none; }
.ap-notif-badge {
  position:absolute; top:-4px; right:-4px;
  width:16px; height:16px; background:#C9A84C;
  border-radius:50%; font-size:.62rem; font-weight:800;
  color:white; display:grid; place-items:center; border:2px solid white;
}
.ap-admin-pill {
  display:flex; align-items:center; gap:8px;
  background:#F8FAFC; border:1.5px solid #E2E8F0;
  border-radius:24px; padding:5px 14px 5px 5px; cursor:pointer; transition:.15s;
}
.ap-admin-pill:hover { border-color:#C9A84C; }
.ap-admin-av {
  width:30px; height:30px;
  background:linear-gradient(135deg,#122649,#C9A84C);
  border-radius:50%; display:grid; place-items:center;
  font-size:.78rem; font-weight:800; color:white;
}
.ap-admin-name { font-size:.82rem; font-weight:600; color:#0D1B2A; }
.ap-admin-role { font-size:.66rem; color:#94A3B8; }
.ap-logout {
  padding:7px 16px; background:#FEF2F2; border:1.5px solid #FECACA;
  border-radius:9px; color:#DC2626; font-size:.8rem; font-weight:700;
  cursor:pointer; font-family:'DM Sans',sans-serif; transition:.15s; letter-spacing:.04em;
}
.ap-logout:hover { background:#FEE2E2; }

/* ── Body Layout ── */
.ap-body { display:flex; flex:1; overflow:hidden; }

/* ── Sidebar ── */
.ap-sidebar {
  width:220px; background:white; border-right:1px solid #E2E8F0;
  flex-shrink:0; display:flex; flex-direction:column;
  overflow-y:auto; padding:20px 12px;
}
.ap-sb-section { margin-bottom:24px; }
.ap-sb-label {
  font-size:.65rem; font-weight:800; color:#94A3B8;
  text-transform:uppercase; letter-spacing:.1em; padding:0 10px; margin-bottom:8px;
}
.ap-sb-item {
  display:flex; align-items:center; gap:9px;
  padding:9px 10px; border-radius:9px; cursor:pointer;
  font-size:.84rem; font-weight:500; color:#64748B; transition:.15s;
  margin-bottom:2px; border:none; background:none; width:100%; text-align:left;
  font-family:'DM Sans',sans-serif;
}
.ap-sb-item:hover { color:#1B3A6B; background:#F1F5F9; }
.ap-sb-item.active { color:#1B3A6B; background:#EEF2FF; font-weight:700; }
.ap-sb-item svg { width:16px; height:16px; stroke:currentColor; fill:none; stroke-width:2; flex-shrink:0; }
.ap-sb-badge {
  margin-left:auto; padding:2px 7px; border-radius:10px;
  font-size:.65rem; font-weight:800; background:#F1F5F9; color:#64748B;
}
.ap-sb-item.active .ap-sb-badge { background:rgba(27,58,107,.1); color:#1B3A6B; }
/* Sidebar system card */
.ap-sb-sys {
  margin:auto 0 0; padding:14px; background:#F8FAFC;
  border-radius:10px; border:1px solid #E2E8F0;
}
.ap-sb-sys-title { font-size:.72rem; font-weight:700; color:#0D1B2A; margin-bottom:10px; }
.ap-sb-sys-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:7px; font-size:.73rem; color:#64748B; }
.ap-sb-sys-dot { width:8px; height:8px; border-radius:50%; }

/* ── Main Content ── */
.ap-main { flex:1; overflow-y:auto; padding:24px 28px; }

/* ── Page Header ── */
.ap-page-hdr { margin-bottom:22px; }
.ap-welcome { font-family:'Playfair Display',serif; font-size:1.7rem; font-weight:800; color:#0D1B2A; margin-bottom:4px; }
.ap-welcome-sub { font-size:.86rem; color:#94A3B8; display:flex; align-items:center; gap:8px; }
.ap-live-dot { width:7px; height:7px; background:#22C55E; border-radius:50%; animation:admPls 2s infinite; flex-shrink:0; }
@keyframes admPls { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(1.4)} }

/* ── Stat Cards ── */
.ap-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:22px; }
.ap-stat {
  background:white; border-radius:12px; padding:18px 20px;
  border:1.5px solid #E2E8F0; transition:.2s; cursor:default;
  box-shadow:0 2px 8px rgba(27,58,107,.04);
}
.ap-stat:hover { border-color:#C9A84C; transform:translateY(-2px); box-shadow:0 6px 20px rgba(201,168,76,.12); }
.ap-stat-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; }
.ap-stat-icon {
  width:40px; height:40px; border-radius:10px;
  display:grid; place-items:center;
}
.ap-stat-icon svg { width:18px; height:18px; fill:none; stroke-width:2; }
.ap-stat-trend {
  font-size:.72rem; font-weight:700; padding:3px 8px;
  border-radius:6px; letter-spacing:.02em;
}
.apt-up { background:#ECFDF5; color:#059669; }
.apt-down { background:#FEF2F2; color:#DC2626; }
.apt-new { background:#FFF7ED; color:#C2410C; }
.ap-stat-num { font-family:'Playfair Display',serif; font-size:1.8rem; font-weight:800; color:#0D1B2A; line-height:1; margin-bottom:4px; }
.ap-stat-label { font-size:.78rem; color:#94A3B8; font-weight:500; }

/* ── 3-col layout for dashboard ── */
.ap-dashboard-grid { display:grid; grid-template-columns:1fr 1fr 300px; gap:16px; }
.ap-dashboard-left { display:flex; flex-direction:column; gap:16px; }
.ap-dashboard-mid  { display:flex; flex-direction:column; gap:16px; }

/* ── Cards ── */
.apc {
  background:white; border-radius:12px; border:1.5px solid #E2E8F0;
  box-shadow:0 2px 8px rgba(27,58,107,.04);
}
.apc-head {
  display:flex; align-items:center; justify-content:space-between;
  padding:16px 20px; border-bottom:1px solid #F1F5F9;
}
.apc-title { font-family:'Playfair Display',serif; font-size:.95rem; font-weight:700; color:#0D1B2A; }
.apc-sub { font-size:.74rem; color:#94A3B8; margin-top:2px; }
.apc-body { padding:16px 20px; }
.apc-live { display:flex; align-items:center; gap:5px; font-size:.7rem; font-weight:700; color:#22C55E; letter-spacing:.05em; text-transform:uppercase; }
.apc-live::before { content:''; width:6px; height:6px; background:#22C55E; border-radius:50%; animation:admPls 2s infinite; }

/* ── Bar Chart ── */
.adm-bar-wrap { display:flex; align-items:flex-end; gap:8px; height:90px; padding-top:8px; }
.adm-bc-col { display:flex; flex-direction:column; align-items:center; gap:4px; flex:1; }
.adm-bc-val { font-size:.65rem; font-weight:700; color:#64748B; }
.adm-bc-bar { width:100%; border-radius:4px 4px 0 0; transition:.8s cubic-bezier(.34,1.56,.64,1); min-height:4px; }
.adm-bc-day { font-size:.65rem; color:#94A3B8; font-weight:500; }

/* ── Donut chart ── */
.adm-donut-wrap { display:flex; align-items:center; gap:20px; padding:4px 0; }
.adm-donut-legend { display:flex; flex-direction:column; gap:8px; }
.adm-dl-item { display:flex; align-items:center; gap:8px; font-size:.78rem; color:#64748B; }
.adm-dl-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }

/* ── Tables ── */
.adm-table { width:100%; border-collapse:collapse; font-size:.82rem; }
.adm-table thead tr { border-bottom:2px solid #F1F5F9; }
.adm-table th { padding:8px 12px; text-align:left; font-size:.7rem; font-weight:800; color:#94A3B8; text-transform:uppercase; letter-spacing:.07em; white-space:nowrap; }
.adm-table td { padding:11px 12px; border-bottom:1px solid #F8FAFC; color:#374151; vertical-align:middle; }
.adm-table tr:hover td { background:#FAFBFF; }
.adm-table tr:last-child td { border-bottom:none; }
/* Status badges */
.adm-badge { display:inline-block; padding:3px 9px; border-radius:5px; font-size:.68rem; font-weight:800; letter-spacing:.05em; text-transform:uppercase; }
.adb-green  { background:#ECFDF5; color:#059669; }
.adb-yellow { background:#FFF7ED; color:#C2410C; }
.adb-blue   { background:#EEF2FF; color:#4338CA; }
.adb-red    { background:#FEF2F2; color:#DC2626; }
.adb-navy   { background:rgba(27,58,107,.08); color:#1B3A6B; }

/* ── Right Quick-Action Panel ── */
.ap-quick-panel { display:flex; flex-direction:column; gap:12px; }
.ap-quick-welcome {
  background:linear-gradient(135deg,#122649,#1B3A6B);
  border-radius:12px; padding:22px;
}
.ap-quick-welcome h3 { font-family:'Playfair Display',serif; font-size:1rem; color:white; font-weight:700; margin-bottom:4px; }
.ap-quick-welcome p { font-size:.76rem; color:rgba(255,255,255,.55); margin-bottom:16px; line-height:1.5; }
.ap-quick-actions { display:flex; flex-direction:column; gap:8px; }
.aq-btn {
  display:flex; align-items:center; gap:10px; padding:10px 14px;
  border-radius:9px; border:none; cursor:pointer; font-size:.82rem;
  font-weight:600; font-family:'DM Sans',sans-serif; transition:.15s; text-align:left; width:100%;
}
.aqb-gold { background:rgba(201,168,76,.15); color:#E8C96B; }
.aqb-gold:hover { background:rgba(201,168,76,.25); }
.aqb-white { background:rgba(255,255,255,.08); color:rgba(255,255,255,.7); }
.aqb-white:hover { background:rgba(255,255,255,.14); color:white; }
.aq-btn svg { width:15px; height:15px; stroke:currentColor; fill:none; stroke-width:2; flex-shrink:0; }

/* Mini workshop cards (right panel) */
.ap-mini-ws { padding:10px 14px; border:1.5px solid #E2E8F0; border-radius:9px; cursor:pointer; transition:.15s; }
.ap-mini-ws:hover { border-color:#C9A84C; background:#FFFBF0; }
.ap-mini-ws-title { font-size:.82rem; font-weight:700; color:#0D1B2A; margin-bottom:4px; }
.ap-mini-ws-meta { font-size:.72rem; color:#94A3B8; }
.ap-mini-seat-bar { height:4px; background:#F1F5F9; border-radius:2px; margin-top:8px; overflow:hidden; }
.ap-mini-seat-fill { height:100%; border-radius:2px; background:linear-gradient(90deg,#A0832A,#C9A84C); }

/* ── Feed ── */
.adm-feed-item { display:flex; align-items:flex-start; gap:10px; padding:10px 0; border-bottom:1px solid #F8FAFC; }
.adm-feed-item:last-child { border-bottom:none; padding-bottom:0; }
.adm-feed-icon { width:32px; height:32px; border-radius:9px; display:grid; place-items:center; font-size:.9rem; flex-shrink:0; }
.adm-feed-text { font-size:.8rem; color:#374151; line-height:1.5; }
.adm-feed-time { font-size:.7rem; color:#94A3B8; margin-top:2px; }

/* ── WORKSHOPS PAGE ── */
.ap-ws-page-grid { display:grid; grid-template-columns:200px 1fr; gap:16px; }
.ap-ws-filter-panel { background:white; border-radius:12px; border:1.5px solid #E2E8F0; padding:18px; height:fit-content; }
.ap-ws-filter-panel h4 { font-size:.75rem; font-weight:800; color:#94A3B8; text-transform:uppercase; letter-spacing:.08em; margin-bottom:12px; }
.ap-ws-filter-item {
  display:flex; align-items:center; gap:8px; padding:8px 10px;
  border-radius:8px; cursor:pointer; font-size:.83rem; font-weight:500;
  color:#64748B; transition:.15s; margin-bottom:2px;
}
.ap-ws-filter-item:hover { color:#1B3A6B; background:#F1F5F9; }
.ap-ws-filter-item.active { color:#1B3A6B; background:#EEF2FF; font-weight:700; }
.ap-ws-filter-item svg { width:14px; height:14px; stroke:currentColor; fill:none; stroke-width:2; flex-shrink:0; }
.ap-ws-right { display:flex; flex-direction:column; gap:14px; }
.ap-ws-toolbar {
  background:white; border-radius:12px; border:1.5px solid #E2E8F0;
  padding:14px 18px; display:flex; align-items:center; gap:10px; flex-wrap:wrap;
}
.ap-ws-search {
  flex:1; min-width:160px; display:flex; align-items:center; gap:8px;
  background:#F8FAFC; border:1.5px solid #E2E8F0; border-radius:8px; padding:8px 12px;
}
.ap-ws-search input { border:none; background:transparent; font-size:.83rem; outline:none; color:#0D1B2A; font-family:'DM Sans',sans-serif; flex:1; }
.ap-ws-search input:focus { color:#0D1B2A; }
.ap-ws-search svg { width:14px; height:14px; stroke:#94A3B8; fill:none; flex-shrink:0; }
.ap-ws-tabs { display:flex; gap:4px; }
.ap-ws-tab {
  padding:7px 14px; border-radius:7px; font-size:.78rem; font-weight:600;
  color:#64748B; border:1.5px solid #E2E8F0; background:white; cursor:pointer;
  transition:.15s; font-family:'DM Sans',sans-serif;
}
.ap-ws-tab.active { background:#EEF2FF; color:#1B3A6B; border-color:#C7D2F8; }
.ap-ws-tab:hover { border-color:#1B3A6B; }
.ap-add-ws-btn {
  padding:8px 18px; background:linear-gradient(135deg,#A0832A,#C9A84C);
  color:white; border:none; border-radius:8px; font-size:.82rem; font-weight:700;
  cursor:pointer; font-family:'DM Sans',sans-serif; letter-spacing:.04em; white-space:nowrap; transition:.15s;
}
.ap-add-ws-btn:hover { transform:translateY(-1px); box-shadow:0 4px 14px rgba(201,168,76,.3); }
/* Workshop cards grid */
.ap-ws-cards { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:14px; }
.ap-wsc {
  background:white; border-radius:12px; border:1.5px solid #E2E8F0;
  overflow:hidden; transition:.2s; cursor:pointer;
}
.ap-wsc:hover { border-color:#C9A84C; transform:translateY(-3px); box-shadow:0 8px 24px rgba(201,168,76,.12); }
.ap-wsc-thumb { height:130px; position:relative; overflow:hidden; }
.ap-wsc-thumb svg { width:100%; height:100%; display:block; }
.ap-wsc-type { position:absolute; top:10px; right:10px; padding:3px 9px; border-radius:4px; font-size:.65rem; font-weight:800; text-transform:uppercase; letter-spacing:.06em; }
.ap-wsc-body { padding:14px; }
.ap-wsc-title { font-weight:700; font-size:.88rem; color:#0D1B2A; margin-bottom:8px; line-height:1.3; }
.ap-wsc-info { display:flex; align-items:center; gap:5px; font-size:.74rem; color:#64748B; margin-bottom:4px; }
.ap-wsc-info svg { width:12px; height:12px; stroke:currentColor; fill:none; stroke-width:2; flex-shrink:0; }
.ap-wsc-bar { height:4px; background:#F1F5F9; border-radius:2px; margin:10px 0 6px; overflow:hidden; }
.ap-wsc-bar-fill { height:100%; border-radius:2px; }
.ap-wsc-foot { display:flex; justify-content:space-between; align-items:center; margin-top:8px; }
.ap-wsc-foot-btn {
  padding:5px 13px; border-radius:6px; font-size:.73rem; font-weight:700;
  cursor:pointer; font-family:'DM Sans',sans-serif; border:none; transition:.15s;
}
.apwfb-view { background:#F1F5F9; color:#1B3A6B; }
.apwfb-view:hover { background:#EEF2FF; }
.apwfb-reg { background:linear-gradient(135deg,#A0832A,#C9A84C); color:white; }
.apwfb-reg:hover { box-shadow:0 3px 10px rgba(201,168,76,.3); transform:translateY(-1px); }

/* ── ADD WORKSHOP FORM ── */
.ap-add-form {
  background:white; border-radius:12px; border:2px dashed #C9A84C;
  padding:24px; margin-bottom:14px; display:none;
}
.ap-add-form h3 { font-family:'Playfair Display',serif; font-size:1rem; font-weight:700; color:#0D1B2A; margin-bottom:16px; display:flex; align-items:center; gap:8px; }
.apf-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px; }
.apf-fg label { display:block; font-size:.7rem; font-weight:800; color:#94A3B8; text-transform:uppercase; letter-spacing:.08em; margin-bottom:5px; }
.apf-fg input, .apf-fg select, .apf-fg textarea {
  width:100%; padding:9px 12px; border:1.5px solid #E2E8F0; border-radius:8px;
  font-size:.83rem; color:#0D1B2A; background:#FAFBFF; outline:none;
  font-family:'DM Sans',sans-serif; transition:.15s;
}
.apf-fg input:focus, .apf-fg select:focus, .apf-fg textarea:focus {
  border-color:#C9A84C; box-shadow:0 0 0 3px rgba(201,168,76,.1);
}
.apf-fg textarea { resize:vertical; min-height:80px; }
.apf-submit {
  padding:10px 24px; background:linear-gradient(135deg,#A0832A,#C9A84C);
  color:white; border:none; border-radius:8px; font-size:.84rem; font-weight:700;
  cursor:pointer; font-family:'DM Sans',sans-serif; letter-spacing:.05em; transition:.2s;
}
.apf-submit:hover { transform:translateY(-1px); box-shadow:0 6px 18px rgba(201,168,76,.35); }

/* ── REGISTRATIONS PAGE ── */
.ap-reg-toolbar {
  background:white; border-radius:12px; border:1.5px solid #E2E8F0;
  padding:14px 18px; display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:14px;
}
.ap-reg-tabs { display:flex; gap:0; border-radius:8px; overflow:hidden; border:1.5px solid #E2E8F0; }
.ap-reg-tab {
  padding:8px 16px; font-size:.79rem; font-weight:600; color:#64748B;
  background:white; cursor:pointer; font-family:'DM Sans',sans-serif;
  border-right:1px solid #E2E8F0; transition:.15s; white-space:nowrap;
}
.ap-reg-tab:last-child { border-right:none; }
.ap-reg-tab.active { background:#EEF2FF; color:#1B3A6B; }
.ap-reg-tab:hover:not(.active) { background:#F8FAFC; }
.ap-reg-filter-row { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
.ap-reg-select {
  padding:7px 12px; border:1.5px solid #E2E8F0; border-radius:8px;
  font-size:.8rem; color:#64748B; background:white; cursor:pointer; outline:none;
  font-family:'DM Sans',sans-serif; transition:.15s;
}
.ap-reg-select:focus { border-color:#C9A84C; }
.ap-reg-btn {
  padding:8px 18px; border-radius:8px; font-size:.8rem; font-weight:700;
  cursor:pointer; font-family:'DM Sans',sans-serif; border:none; transition:.15s; letter-spacing:.04em;
}
.adrb-gold { background:linear-gradient(135deg,#A0832A,#C9A84C); color:white; }
.adrb-gold:hover { box-shadow:0 4px 12px rgba(201,168,76,.3); }
.adrb-outline { background:white; color:#1B3A6B; border:1.5px solid #E2E8F0; }
.adrb-outline:hover { border-color:#1B3A6B; background:#EEF2FF; }

/* ── NOTIFICATIONS PAGE ── */
.ap-notif-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
.notif-to-wrap { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:14px; }
.ntag {
  padding:5px 12px; border-radius:20px; border:1.5px solid #E2E8F0;
  font-size:.76rem; font-weight:600; color:#64748B; cursor:pointer; transition:.15s;
}
.ntag.sel { background:#EEF2FF; color:#1B3A6B; border-color:#C7D2F8; }
.ntag:hover:not(.sel) { border-color:#1B3A6B; }
.ntag-label { font-size:.65rem; color:#94A3B8; text-transform:uppercase; letter-spacing:.08em; font-weight:800; margin-bottom:8px; }
.notif-msg-area {
  width:100%; min-height:110px; padding:12px 14px;
  border:1.5px solid #E2E8F0; border-radius:10px;
  font-size:.84rem; font-family:'DM Sans',sans-serif;
  color:#0D1B2A; resize:vertical; outline:none; transition:.15s;
}
.notif-msg-area:focus { border-color:#C9A84C; box-shadow:0 0 0 3px rgba(201,168,76,.1); }
.notif-send-row { display:flex; gap:8px; margin-top:12px; }
.ns-btn {
  padding:9px 20px; border-radius:8px; font-size:.82rem; font-weight:700;
  cursor:pointer; font-family:'DM Sans',sans-serif; border:none; transition:.15s; letter-spacing:.04em;
}
.nsb-gold { background:linear-gradient(135deg,#A0832A,#C9A84C); color:white; }
.nsb-gold:hover { box-shadow:0 4px 12px rgba(201,168,76,.3); }
.nsb-outline { background:white; color:#64748B; border:1.5px solid #E2E8F0; }

/* ── ANALYTICS PAGE ── */
